{
  "rewrites": [
    { "source": "/api/foursquare/:path*", "destination": "/api/foursquare" },
    { "source": "/api/claude/:path*", "destination": "/api/claude" },
    { "source": "/api/calendar", "destination": "/api/calendar" },
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ]
}
